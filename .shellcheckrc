# ShellCheck configuration for the YUM/DNF agent plugin.
# See https://www.shellcheck.net/wiki/

# Use bash as the default shell
shell=bash

# Enable all optional checks
enable=all

# Disable specific checks:
# SC2034: Variable appears unused (some are used by sourcing scripts)
# SC1090: Can't follow non-constant source (we source /etc/os-release)
# SC1091: Not following sourced file (external files)
# SC2250: Prefer braces around variable references (style preference)
# SC2249: Consider adding a default *) case (handled by our logic)
disable=SC2034,SC1090,SC1091,SC2250,SC2249

# External sources - variables provided by /etc/os-release
external-sources=true

# Source path for sourced scripts
source-path=SCRIPTDIR

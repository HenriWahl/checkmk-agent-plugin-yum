#!/bin/bash
# CheckMK Agent Plugin: YUM/DNF Update Check
#
# Checks for available package updates on RPM-based distributions.
# Supports: Red Hat Enterprise Linux 8-10 and compatible distributions
#           (AlmaLinux, Rocky Linux, Oracle Linux, CentOS Stream)
# Package managers: dnf5 (RHEL 10+), dnf (RHEL 8-9), yum (as dnf wrapper)
#
# Output format (<<<yum>>> section):
#   Line 1: Reboot required (yes/no)
#   Line 2: Number of available updates (-1 on error)
#   Line 3: Number of security updates [-1 error, -2 unsupported] [comma-separated list]
#   Line 4: Unix timestamp of last update (-1 if unknown)
#
# Copyright 2015, Henri Wahl <h.wahl@ifw-dresden.de>
# Copyright 2018, Moritz Schlarb <schlarbm@uni-mainz.de>
# Copyright 2021, Marco Lenhardt <marco.lenhardt@ontec.at>
# Copyright 2021, Henrik Giessel <henrik.giessel@yahoo.de>
# Copyright 2023, Timo Klecker <klecker@decoit.de>
# Copyright 2026, Felix Kraus <felix.kraus@mhb.de>
#
# License: GPLv3+

# Set the version to be captured in newer versions of CheckMK inventory
CMK_VERSION="0.0.0"

# Disable globbing to prevent accidental pathname expansion
set -o noglob

# --- Constants ---
readonly CMD_TIMEOUT=25

# --- Output error and exit gracefully ---
# Exit 0 so the Checkmk agent continues processing other plugins.
# The server-side check plugin handles the ERROR: prefix.
die() {
    echo "<<<yum>>>"
    echo "ERROR: $1"
    exit 0
}

# --- Validate environment ---
if [[ -z "${MK_VARDIR:-}" ]]; then
    die "MK_VARDIR not set - agent environment unavailable"
fi

# --- Cache file paths ---
readonly CACHE_RESULT="${MK_VARDIR}/cache/yum_result.cache"
readonly CACHE_PKG_STATE="${MK_VARDIR}/cache/yum_pkg_state.cache"
readonly CACHE_PREV_UPTIME="${MK_VARDIR}/cache/yum_uptime.cache"

# --- Cache file helpers ---

validate_cache_file() {
    local filepath="$1"
    if [[ -L "$filepath" ]]; then
        die "Cache file is a symlink: ${filepath}"
    fi
    if [[ -e "$filepath" && ! -f "$filepath" ]]; then
        die "Cache path is not a regular file: ${filepath}"
    fi
}

init_cache_file() {
    local filepath="$1"
    local default_content="${2:-}"
    if [[ ! -e "$filepath" ]]; then
        echo -n "$default_content" > "$filepath"
    fi
    validate_cache_file "$filepath"
}

# --- Detect distribution ---

detect_distribution() {
    # Variables from /etc/os-release (SC2154)
    # shellcheck disable=SC2154
    if [[ -f /etc/os-release ]]; then
        # shellcheck source=/dev/null
        . /etc/os-release
        MAJOR_VERSION="${VERSION_ID%%.*}"

        # Normalise to RHEL family using ID_LIKE
        if [[ "${ID_LIKE:-}" == *rhel* ]] || [[ "${ID}" == "rhel" ]]; then
            DISTRO_ID="rhel"
        else
            DISTRO_ID="${ID}"
        fi
    else
        MAJOR_VERSION=0
        DISTRO_ID="unknown"
    fi
}

# --- Detect package manager ---

detect_package_manager() {
    if command -v dnf5 >/dev/null 2>&1; then
        PKG_MGR="dnf5"
    elif command -v dnf >/dev/null 2>&1; then
        PKG_MGR="dnf"
    elif command -v yum >/dev/null 2>&1; then
        PKG_MGR="yum"
    else
        die "No supported package manager found (dnf5, dnf, or yum)"
    fi
}

# --- Wait for other package manager instances ---

wait_for_package_manager() {
    local attempts=0
    while pgrep -f "(python|/usr/bin/).*(yum|dnf)" >/dev/null 2>&1; do
        if (( attempts >= 3 )); then
            die "Another package manager instance still running after 30s"
        fi
        (( attempts++ ))
        sleep 10
    done
}

# --- Check if kernel update requires reboot ---

check_reboot_required() {
    local kernel_package running_kernel latest_kernel

    kernel_package=$(rpm -qf --qf "%{NAME}" "/boot/config-$(uname -r)" 2>/dev/null) || true
    if [[ -z "$kernel_package" ]]; then
        echo "no"
        return
    fi

    running_kernel=$(rpm -qf --qf "%{VERSION}-%{RELEASE}\n" "/boot/config-$(uname -r)" 2>/dev/null) || true
    latest_kernel=$(rpm -q --qf "%{INSTALLTIME} %{VERSION}-%{RELEASE}\n" "$kernel_package" 2>/dev/null \
        | sort -nr | head -n1 | cut -d' ' -f2-) || true

    if [[ "$running_kernel" == "$latest_kernel" ]]; then
        echo "no"
    else
        echo "yes"
    fi
}

# --- Count available package updates ---

count_updates() {
    local count
    case "$PKG_MGR" in
        dnf5)
            count=$(timeout "${CMD_TIMEOUT}s" dnf5 -C --quiet list --upgrades 2>/dev/null \
                | grep -cE '^[a-zA-Z0-9]') || true
            ;;
        dnf|yum)
            count=$(timeout "${CMD_TIMEOUT}s" "$PKG_MGR" -C --noplugins --quiet list updates 2>/dev/null \
                | grep -c '\.') || true
            ;;
    esac
    echo "${count:-0}"
}

# --- Count security updates and list affected packages ---

count_security_updates() {
    local output count pkg_list
    output=""
    count=0
    pkg_list=""

    case "$PKG_MGR" in
        dnf5)
            output=$(timeout "${CMD_TIMEOUT}s" dnf5 -C --quiet check-upgrade --security 2>/dev/null) || true
            if [[ -n "$output" ]]; then
                count=$(grep -cE '^[a-zA-Z0-9]' <<< "$output") || count=0
                pkg_list=$(grep -E '^[a-zA-Z0-9]' <<< "$output" \
                    | awk '{print $1}' | sed 's/\.[^.]*$//' | paste -sd, -) || true
            fi
            ;;
        dnf|yum)
            if timeout "${CMD_TIMEOUT}s" "$PKG_MGR" -C --noplugins --quiet --security list updates >/dev/null 2>&1; then
                output=$(timeout "${CMD_TIMEOUT}s" "$PKG_MGR" -C --noplugins --quiet --security list updates 2>/dev/null) || true
                if [[ -n "$output" ]]; then
                    count=$(grep -c '\.' <<< "$output") || count=0
                    pkg_list=$(grep '\.' <<< "$output" \
                        | awk '{print $1}' | sed 's/\.[^.]*$//' | paste -sd, -) || true
                fi
            else
                # --security flag not supported on this system
                echo "-2"
                return
            fi
            ;;
    esac

    printf '%s %s\n' "${count:-0}" "${pkg_list:-}"
}

# --- Determine timestamp of last successful update ---

get_last_update_timestamp() {
    local timestamp=""

    case "$PKG_MGR" in
        dnf5)
            timestamp=$(dnf5 history list 2>/dev/null \
                | awk '/[Uu]pgrade|[Uu]pdate/ {print $5" "$6}' \
                | head -n1 \
                | date -f - +"%s" 2>/dev/null) || true
            ;;
        dnf|yum)
            timestamp=$("$PKG_MGR" -C --quiet --noplugins history list 2>/dev/null \
                | awk '{if(NR>2)print}' \
                | grep -E ' U | Upgrade| Update' \
                | head -n1 \
                | awk -F'|' '{print $3}' \
                | date -f - +"%s" 2>/dev/null) || true
            ;;
    esac

    echo "${timestamp:--1}"
}

# --- Detect system reboot by comparing uptime ---

check_for_reboot() {
    local current_uptime prev_uptime

    current_uptime=$(cut -d" " -f1 /proc/uptime | cut -d"." -f1)
    prev_uptime=$(cat "$CACHE_PREV_UPTIME" 2>/dev/null) || true
    : "${prev_uptime:=0}"

    printf '%s\n' "$current_uptime" > "$CACHE_PREV_UPTIME"

    if (( current_uptime < prev_uptime )); then
        # System was rebooted — clear stale results
        : > "$CACHE_RESULT"
        return 0
    fi
    return 1
}

# --- Package cache fingerprint (detects repo metadata changes) ---

get_pkg_state_fingerprint() {
    # Use explicit paths to avoid brace expansion issues in some shells
    ls -lR /var/cache/yum/ /var/cache/dnf/ 2>/dev/null || true
}

# --- Main ---

main() {
    detect_distribution
    detect_package_manager

    # Initialise cache files
    init_cache_file "$CACHE_RESULT"
    init_cache_file "$CACHE_PKG_STATE"
    init_cache_file "$CACHE_PREV_UPTIME" "0"

    echo "<<<yum>>>"

    # Clear cache on reboot
    check_for_reboot || true

    # Compare fingerprint to decide whether a fresh check is needed
    local current_state cached_state
    current_state=$(get_pkg_state_fingerprint)
    cached_state=$(cat "$CACHE_PKG_STATE" 2>/dev/null) || true
    : "${cached_state:=}"

    if [[ "$current_state" != "$cached_state" ]] || [[ ! -s "$CACHE_RESULT" ]]; then
        wait_for_package_manager

        local boot_required updates security_info last_timestamp
        boot_required=$(check_reboot_required)
        updates=$(count_updates)
        security_info=$(count_security_updates)
        last_timestamp=$(get_last_update_timestamp)

        # Output results
        echo "$boot_required"
        echo "$updates"
        echo "$security_info"
        echo "$last_timestamp"

        # Persist fingerprint
        validate_cache_file "$CACHE_PKG_STATE"
        printf '%s\n' "$current_state" > "$CACHE_PKG_STATE"

        # Persist results
        validate_cache_file "$CACHE_RESULT"
        {
            echo "$boot_required"
            echo "$updates"
            echo "$security_info"
            echo "$last_timestamp"
        } > "$CACHE_RESULT"
    else
        # Serve from cache
        cat "$CACHE_RESULT"
    fi
}

main
